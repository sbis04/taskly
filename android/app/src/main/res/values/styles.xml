<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting when the Flutter UI is delayed. This theme can be extended from any AppCompat theme. -->
    <style name="LaunchTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Show a splash screen on the activity. Automatically removed when the Flutter engine is ready. -->
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Optional: If you want to match the status bar color as well -->
        <item name="android:statusBarColor">@color/primary_background_color</item>
        <item name="android:navigationBarColor">@color/primary_background_color</item>
    </style>

    <!-- Theme applied to the Android Window as soon as the Flutter UI is rendered. This theme should be extended from an AppCompat theme. -->
    <style name="NormalTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>